---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE, ECOSYSTEM, PRZEDMIOT_ZADANIA } from "../../../config/site";
import kierunkiData from "../../../data/kierunki.json";
import notesData from "../../../data/kierunki-notes.json";

interface Przedmiot {
  slug: string;
  nazwa: string;
  maxWaga?: number;
}
interface Kierunek {
  slug: string;
  name: string;
  kategoria: string;
  liczbaUczelni: number;
  rdzen: Przedmiot[];
  kluczowe: Przedmiot[];
  pomocnicze: Przedmiot[];
  uczelnie: { uczelniaSlug: string; maxPkt: number; link: string }[];
}
interface Note {
  rekomendacja: string;
  trudnosc: string;
  typoweBledy: string;
}

export async function getStaticPaths() {
  const lista = kierunkiData as Kierunek[];
  return lista.map((k) => ({
    params: { kierunek: k.slug },
    props: { k, note: (notesData as Record<string, Note>)[k.slug] ?? null },
  }));
}

const { k, note } = Astro.props as { k: Kierunek; note: Note | null };

// deep-link do naszej bazy zadań (jeśli mamy przedmiot)
function zadaniaUrl(slug: string): string | null {
  const s = PRZEDMIOT_ZADANIA[slug];
  return s ? `/${s}/zadania/` : null;
}

const uczelnieUnikalne = [...new Map(k.uczelnie.map((u) => [u.uczelniaSlug, u])).values()];
const UCZELNIA_NAZWA: Record<string, string> = {
  wum: "WUM", "cm-uj": "CM UJ", "um-lodz": "UM Łódź", uw: "UW", uj: "UJ", agh: "AGH",
  pw: "Politechnika Warszawska", sgh: "SGH", ug: "UG", sggw: "SGGW", pk: "Politechnika Krakowska",
};

const rdzenNazwy = k.rdzen.map((p) => p.nazwa).join(" + ");
const title =
  k.rdzen.length > 0
    ? `Jakie rozszerzenia na ${k.name.toLowerCase()}? Rdzeń: ${rdzenNazwy} | ${SITE.name}`
    : `Jakie rozszerzenia na ${k.name.toLowerCase()}? Poradnik wyboru przedmiotów | ${SITE.name}`;
const description = note
  ? note.rekomendacja.slice(0, 155)
  : `Które przedmioty rozszerzone wybrać na kierunek ${k.name.toLowerCase()} — wymagania i alternatywy.`;

const faq = [
  note && {
    "@type": "Question",
    name: `Jakie rozszerzenia wybrać na ${k.name.toLowerCase()}?`,
    acceptedAnswer: { "@type": "Answer", text: note.rekomendacja },
  },
  note && {
    "@type": "Question",
    name: `Czy ${k.name.toLowerCase()} to trudna rekrutacja?`,
    acceptedAnswer: { "@type": "Answer", text: note.trudnosc },
  },
].filter(Boolean);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Start", item: SITE.url },
      { "@type": "ListItem", position: 2, name: "Wybór rozszerzeń", item: `${SITE.url}/wybor-rozszerzen/` },
      { "@type": "ListItem", position: 3, name: k.name, item: `${SITE.url}/wybor-rozszerzen/${k.slug}/` },
    ],
  },
  faq.length > 0 && { "@context": "https://schema.org", "@type": "FAQPage", mainEntity: faq },
].filter(Boolean);
---

<BaseLayout title={title} description={description} schema={schema}>
  <nav class="mb-4 text-sm text-slate-500">
    <a href="/" class="hover:text-indigo-700">Start</a> ›
    <a href="/wybor-rozszerzen/" class="hover:text-indigo-700">Wybór rozszerzeń</a> › {k.name}
  </nav>

  <h1 class="mb-3 text-3xl font-extrabold tracking-tight">
    Jakie rozszerzenia wybrać na {k.name.toLowerCase()}?
  </h1>

  {note && <p class="mb-6 max-w-2xl text-lg text-slate-700">{note.rekomendacja}</p>}

  <!-- Przedmioty pogrupowane rolą -->
  <section class="mb-8 grid gap-4 sm:grid-cols-3">
    <div class="rounded-xl border border-emerald-200 bg-emerald-50 p-4">
      <p class="mb-2 text-sm font-bold text-emerald-800">Rdzeń (obowiązkowe)</p>
      {k.rdzen.length > 0 ? (
        <ul class="space-y-1">
          {k.rdzen.map((p) => (
            <li>
              {zadaniaUrl(p.slug) ? (
                <a href={zadaniaUrl(p.slug)} class="font-medium text-emerald-900 hover:underline">
                  {p.nazwa}
                </a>
              ) : (
                <span class="font-medium text-emerald-900">{p.nazwa}</span>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-emerald-800">Brak sztywnego rdzenia — zestaw jest elastyczny.</p>
      )}
    </div>

    <div class="rounded-xl border border-indigo-200 bg-indigo-50 p-4">
      <p class="mb-2 text-sm font-bold text-indigo-800">Mocno punktowane</p>
      {k.kluczowe.length > 0 ? (
        <ul class="space-y-1">
          {k.kluczowe.map((p) => (
            <li>
              {zadaniaUrl(p.slug) ? (
                <a href={zadaniaUrl(p.slug)} class="font-medium text-indigo-900 hover:underline">
                  {p.nazwa}
                </a>
              ) : (
                <span class="font-medium text-indigo-900">{p.nazwa}</span>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-indigo-700">Zależnie od uczelni — patrz kalkulator.</p>
      )}
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <p class="mb-2 text-sm font-bold text-slate-700">Alternatywy / dodatkowe</p>
      {k.pomocnicze.length > 0 ? (
        <ul class="space-y-1">
          {k.pomocnicze.map((p) => (
            <li>
              {zadaniaUrl(p.slug) ? (
                <a href={zadaniaUrl(p.slug)} class="text-slate-700 hover:underline">{p.nazwa}</a>
              ) : (
                <span class="text-slate-700">{p.nazwa}</span>
              )}
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-sm text-slate-500">—</p>
      )}
    </div>
  </section>

  {note && (
    <section class="mb-8 space-y-4">
      <div class="rounded-xl border border-slate-200 bg-white p-5">
        <h2 class="mb-1 font-bold">Czy {k.name.toLowerCase()} to trudna rekrutacja?</h2>
        <p class="text-slate-700">{note.trudnosc}</p>
      </div>
      <div class="rounded-xl border border-amber-200 bg-amber-50 p-5">
        <h2 class="mb-1 font-bold text-amber-900">Najczęstszy błąd przy wyborze</h2>
        <p class="text-amber-900">{note.typoweBledy}</p>
      </div>
    </section>
  )}

  <!-- CTA kalkulator -->
  <aside class="mb-8 rounded-xl border border-indigo-200 bg-indigo-50 p-5">
    <p class="font-semibold text-indigo-900">Policz swoje punkty na {k.name.toLowerCase()}</p>
    <p class="mt-1 text-sm text-indigo-800">
      Realne wzory różnią się między uczelniami. Kalkulator punktów na Maturalnie.pl przeliczy Twój
      wynik na punkty rekrutacyjne konkretnej uczelni i porówna z ostatnim progiem.
    </p>
    <a
      href={ECOSYSTEM.kalkulator}
      class="mt-3 inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700"
      >Otwórz kalkulator punktów →</a
    >
  </aside>

  {uczelnieUnikalne.length > 0 && (
    <section class="mb-8">
      <h2 class="mb-3 text-lg font-bold">Gdzie studiować — rekrutacja</h2>
      <ul class="flex flex-wrap gap-2 text-sm">
        {uczelnieUnikalne.map((u) => (
          <li>
            <a
              href={u.link}
              rel="nofollow"
              class="inline-block rounded-full border border-slate-200 bg-white px-3 py-1 hover:border-indigo-400"
            >
              {UCZELNIA_NAZWA[u.uczelniaSlug] ?? u.uczelniaSlug} — rekrutacja
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  <p class="text-sm text-slate-500">
    Masz już wybrane rozszerzenia? Przećwicz zadania z arkuszy CKE w naszej
    <a href="/" class="font-semibold text-indigo-700 hover:underline"> bazie zadań rozszerzonych</a>
    albo rozwiązuj interaktywnie w
    <a href={ECOSYSTEM.app} class="font-semibold text-indigo-700 hover:underline"> aplikacji Matury-Online.pl</a>.
  </p>
</BaseLayout>
