---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE, SUBJECTS, ECOSYSTEM } from "../config/site";
import terminy from "../data/terminy.json";

// Załaduj słowniki działów wszystkich przedmiotów, które mają dane
const dzialyModules = import.meta.glob<{ default: { slug: string; nazwa: string; count: number }[] }>(
  "../data/dzialy/*.json",
  { eager: true }
);
const subjects = Object.entries(dzialyModules).map(([path, mod]) => {
  const slug = path.match(/\/([\w-]+)\.json$/)![1];
  return { meta: SUBJECTS[slug], dzialy: mod.default };
}).filter((s) => s.meta).sort((a, b) => a.meta.name.localeCompare(b.meta.name));

const totalZadan = subjects.reduce((s, x) => s + x.dzialy.reduce((a, d) => a + d.count, 0), 0);
const totalDzialow = subjects.reduce((s, x) => s + x.dzialy.filter((d) => d.count > 0).length, 0);

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
  },
];
---

<BaseLayout title={`${SITE.name} — ${SITE.tagline}`} description={SITE.description} schema={schema}>
  <section class="mb-8">
    <h1 class="mb-3 text-3xl font-extrabold tracking-tight sm:text-4xl">
      Matura rozszerzona — zadania, wymagania i strategia
    </h1>
    <p class="mb-5 max-w-2xl text-lg text-slate-600">
      {totalZadan} zadań z arkuszy maturalnych CKE na poziomie rozszerzonym, pogrupowanych w
      {totalDzialow} działów tematycznych — z odpowiedziami, typowymi pułapkami i pełnymi
      rozwiązaniami. Plus poradnik wyboru rozszerzeń pod kierunek studiów.
    </p>
    <div class="flex flex-wrap gap-3">
      <a href="/wybor-rozszerzen/" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
        Co wybrać na rozszerzenie? →
      </a>
      <a href="/terminy/" class="rounded-lg border border-indigo-200 bg-white px-4 py-2 text-sm font-semibold text-indigo-700 hover:border-indigo-400">
        Terminy matury {terminy.rok} →
      </a>
    </div>
  </section>

  <!-- Przedmioty: karty z linkami do hubu, zadań i wymagań -->
  <section class="mb-10">
    <h2 class="mb-4 text-xl font-bold">Przedmioty rozszerzone</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {subjects.map(({ meta, dzialy }) => {
        const n = dzialy.reduce((a, d) => a + d.count, 0);
        return (
          <div class="flex flex-col rounded-xl border border-slate-200 bg-white p-4">
            <a href={`/${meta.slug}/`} class="text-lg font-bold hover:text-indigo-700">{meta.name}</a>
            <p class="mb-3 mt-0.5 text-sm text-slate-500">{n} zadań w {dzialy.filter((d) => d.count > 0).length} działach</p>
            <div class="mt-auto flex flex-wrap gap-x-3 gap-y-1 text-sm">
              <a href={`/${meta.slug}/zadania/`} class="font-medium text-indigo-700 hover:underline">Zadania</a>
              <a href={`/${meta.slug}/wymagania/`} class="font-medium text-indigo-700 hover:underline">Wymagania</a>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Pełna lista działów per przedmiot (SEO + nawigacja) -->
  {subjects.map(({ meta, dzialy }) => (
    <section class="mb-8">
      <h2 class="mb-3 text-xl font-bold">
        <a href={`/${meta.slug}/`} class="hover:text-indigo-700">{meta.name} — działy</a>
      </h2>
      <ul class="grid gap-2 sm:grid-cols-2">
        {dzialy.filter((d) => d.count > 0).map((d) => (
          <li>
            <a href={`/${meta.slug}/zadania/${d.slug}/`} class="flex items-center justify-between rounded-lg border border-slate-200 bg-white px-4 py-3 hover:border-indigo-400">
              <span class="font-medium">{d.nazwa}</span>
              <span class="ml-3 shrink-0 rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-semibold text-indigo-700">{d.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  ))}

  <aside class="mt-10 rounded-xl border border-indigo-200 bg-indigo-50 p-5">
    <p class="font-semibold text-indigo-900">Chcesz rozwiązywać zadania interaktywnie?</p>
    <p class="mt-1 text-sm text-indigo-800">
      Aplikacja Matury-Online.pl to arkusze i zadania z automatycznym sprawdzaniem odpowiedzi
      i śledzeniem postępów — idealne uzupełnienie powtórek.
    </p>
    <a href={ECOSYSTEM.app} class="mt-3 inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
      Przejdź do aplikacji →
    </a>
  </aside>
</BaseLayout>
