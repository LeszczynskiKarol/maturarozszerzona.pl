---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { SITE, SUBJECTS, ECOSYSTEM } from "../../../config/site";

export async function getStaticPaths() {
  const dzialyModules = import.meta.glob<{ default: { slug: string; nazwa: string; count: number }[] }>(
    "../../../data/dzialy/*.json",
    { eager: true }
  );
  return Object.entries(dzialyModules).map(([path, mod]) => {
    const slug = path.match(/\/([\w-]+)\.json$/)![1];
    return { params: { przedmiot: slug }, props: { dzialy: mod.default } };
  });
}

const { przedmiot } = Astro.params;
const { dzialy } = Astro.props;
const meta = SUBJECTS[przedmiot!];
const total = dzialy.reduce((s, d) => s + d.count, 0);

const title = `Zadania z ${meta.dopelniacz} — matura rozszerzona (działy) | ${SITE.name}`;
const description = `Zadania z matur rozszerzonych CKE z ${meta.dopelniacz} pogrupowane działami: ${dzialy
  .slice(0, 4)
  .map((d) => d.nazwa.split(":")[0].toLowerCase())
  .join(", ")}... Z odpowiedziami i wskazówkami.`;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Start", item: SITE.url },
      { "@type": "ListItem", position: 2, name: meta.name, item: `${SITE.url}/${meta.slug}/zadania/` },
    ],
  },
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <nav class="mb-4 text-sm text-slate-500">
    <a href="/" class="hover:text-indigo-700">Start</a> ›
    <a href={`/${meta.slug}/`} class="hover:text-indigo-700">{meta.name}</a> › Zadania
  </nav>

  <h1 class="mb-3 text-3xl font-extrabold tracking-tight">
    {meta.name} — zadania z matur rozszerzonych według działów
  </h1>
  <p class="mb-8 max-w-2xl text-slate-600">
    {total} zadań z oficjalnych arkuszy CKE (poziom rozszerzony), pogrupowanych tematycznie.
    Każde z odpowiedzią, typową pułapką i linkiem do pełnego rozwiązania.
  </p>

  <ul class="grid gap-3 sm:grid-cols-2">
    {dzialy.filter((d) => d.count > 0).map((d) => (
      <li>
        <a
          href={`/${meta.slug}/zadania/${d.slug}/`}
          class="flex h-full items-center justify-between rounded-xl border border-slate-200 bg-white px-4 py-4 hover:border-indigo-400"
        >
          <span class="font-semibold">{d.nazwa}</span>
          <span class="ml-3 shrink-0 rounded-full bg-indigo-50 px-2 py-0.5 text-xs font-semibold text-indigo-700">
            {d.count} zadań
          </span>
        </a>
      </li>
    ))}
  </ul>

  <aside class="mt-10 rounded-xl border border-indigo-200 bg-indigo-50 p-5">
    <p class="font-semibold text-indigo-900">Chcesz rozwiązywać te zadania interaktywnie?</p>
    <p class="mt-1 text-sm text-indigo-800">
      W aplikacji Matury-Online.pl ćwiczysz zadania z {meta.dopelniacz} z automatycznym sprawdzaniem
      odpowiedzi i śledzeniem postępów.
    </p>
    <a
      href={meta.appUrl}
      class="mt-3 inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700"
      >Przejdź do aplikacji →</a
    >
  </aside>
</BaseLayout>
