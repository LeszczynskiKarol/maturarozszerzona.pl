---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { SITE } from "../../config/site";
import terminy from "../../data/terminy.json";

interface Egzamin {
  przedmiot: string;
  srcSlug: string;
  poziom: string;
  dataIso: string;
  godzina: string;
  czasTrwania: number;
  obowiazkowy: boolean;
  hubSlug: string | null;
}
const dane = terminy as {
  rok: number;
  oficjalna: boolean;
  startIso: string;
  koniecIso: string;
  poprawkowaIso: string | null;
  deklaracjaWstepna: string;
  deklaracjaOstateczna: string;
  egzaminyPR: Egzamin[];
};

const MIESIACE = ["stycznia", "lutego", "marca", "kwietnia", "maja", "czerwca", "lipca", "sierpnia", "września", "października", "listopada", "grudnia"];
const DNI = ["niedziela", "poniedziałek", "wtorek", "środa", "czwartek", "piątek", "sobota"];
function pl(iso: string): string {
  const d = new Date(`${iso}T12:00:00`);
  return `${d.getDate()} ${MIESIACE[d.getMonth()]} ${d.getFullYear()}`;
}
function dzien(iso: string): string {
  return DNI[new Date(`${iso}T12:00:00`).getDay()];
}

const title = `Terminy matury rozszerzonej ${dane.rok} — harmonogram CKE | ${SITE.name}`;
const description = `Kiedy jest matura rozszerzona ${dane.rok}? Harmonogram egzaminów CKE na poziomie rozszerzonym: daty, godziny i czas trwania każdego przedmiotu${dane.oficjalna ? "" : " (terminy orientacyjne)"}.`;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Start", item: SITE.url },
      { "@type": "ListItem", position: 2, name: "Terminy", item: `${SITE.url}/terminy/` },
    ],
  },
];
---

<BaseLayout title={title} description={description} schema={schema}>
  <nav class="mb-4 text-sm text-slate-500">
    <a href="/" class="hover:text-indigo-700">Start</a> › Terminy
  </nav>

  <h1 class="mb-3 text-3xl font-extrabold tracking-tight">
    Terminy matury rozszerzonej {dane.rok}
  </h1>
  <p class="mb-6 max-w-2xl text-slate-600">
    Harmonogram egzaminów maturalnych na poziomie rozszerzonym w sesji {dane.rok}. Sesja główna
    rozpoczyna się {pl(dane.startIso)}, a egzaminy rozszerzone odbywają się w kolejnych dniach.
  </p>

  {!dane.oficjalna && (
    <p class="mb-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
      <strong>Uwaga:</strong> daty na {dane.rok} rok są orientacyjne (na podstawie wieloletniego
      wzorca — matura startuje na początku maja). Oficjalny harmonogram CKE publikowany jest zwykle
      w sierpniu roku poprzedzającego. Zweryfikuj daty w komunikacie CKE przed planowaniem.
    </p>
  )}

  <div class="mb-8 overflow-x-auto">
    <table class="w-full min-w-[36rem] border-collapse text-sm">
      <thead>
        <tr class="border-b border-slate-300 text-left text-slate-500">
          <th class="py-2 pr-4 font-semibold">Data</th>
          <th class="py-2 pr-4 font-semibold">Przedmiot (PR)</th>
          <th class="py-2 pr-4 font-semibold">Godzina</th>
          <th class="py-2 font-semibold">Czas</th>
        </tr>
      </thead>
      <tbody>
        {dane.egzaminyPR.map((e) => (
          <tr class="border-b border-slate-100">
            <td class="py-2 pr-4 whitespace-nowrap text-slate-600">
              {pl(e.dataIso)}<span class="block text-xs text-slate-400">{dzien(e.dataIso)}</span>
            </td>
            <td class="py-2 pr-4 font-medium">
              {e.hubSlug ? (
                <a href={`/${e.hubSlug}/`} class="text-indigo-700 hover:underline">{e.przedmiot}</a>
              ) : (
                e.przedmiot
              )}
            </td>
            <td class="py-2 pr-4 text-slate-600">{e.godzina}</td>
            <td class="py-2 text-slate-600">{e.czasTrwania} min</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <section class="mb-8 grid gap-4 sm:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-5">
      <h2 class="mb-2 font-bold">Ważne terminy formalne</h2>
      <ul class="space-y-1 text-sm text-slate-700">
        <li><strong>Deklaracja wstępna:</strong> do {pl(dane.deklaracjaWstepna)} — wybór przedmiotów dodatkowych.</li>
        <li><strong>Deklaracja ostateczna:</strong> do {pl(dane.deklaracjaOstateczna)} — po tym terminie zmiana nie jest możliwa.</li>
        {dane.poprawkowaIso && <li><strong>Sesja poprawkowa:</strong> {pl(dane.poprawkowaIso)}.</li>}
      </ul>
    </div>
    <div class="rounded-xl border border-indigo-200 bg-indigo-50 p-5">
      <h2 class="mb-2 font-bold text-indigo-900">Jeszcze nie wiesz, co zdawać?</h2>
      <p class="text-sm text-indigo-800">
        Wybór rozszerzeń zadeklarujesz właśnie do {pl(dane.deklaracjaWstepna)}. Sprawdź, które
        przedmioty otwierają wymarzony kierunek.
      </p>
      <a href="/wybor-rozszerzen/" class="mt-3 inline-block rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">
        Poradnik wyboru rozszerzeń →
      </a>
    </div>
  </section>

  <p class="text-sm text-slate-500">
    Masz już plan? Zacznij powtórki od <a href="/" class="font-semibold text-indigo-700 hover:underline">zadań z arkuszy CKE</a> pogrupowanych działami.
  </p>
</BaseLayout>
